# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is described as a memory release flaw
# in the Custom Reports module of Progress MOVEit Transfer [1][2], triggered
# by network requests requiring no authentication (AV:N/PR:N/UI:N) [1].
# The match targets HTTP requests to the Custom Reports endpoint path, which
# is the observable network surface described in the advisory [2]. No deeper
# protocol-level exploit signature (e.g., specific payload bytes or headers)
# can be derived without PoC code or advisory technical detail beyond what
# was provided.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# ANALYST REVIEW REQUIRED before deployment: the URI path match below is
# inferred from MOVEit Transfer's known Custom Reports module routing and
# the advisory description [2]. If Progress publishes a more detailed
# bulletin, this rule should be revised accordingly.
#
# ⚠ SEVERITY NOTE: The CVE description states "denial of service" as the
# primary impact, but the RCE flag (AV:N/PR:N/UI:N) supplied in the
# enrichment metadata contradicts this. Analysts should verify the true
# impact scope against [1][2][3] before trusting classtype:attempted-admin
# below — classtype:denial-of-service may be more appropriate pending
# confirmation.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-10699 Progress MOVEit Transfer Custom Reports memory exhaustion DoS attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/moveitisapi/moveitisapi.dll"; nocase;
  pcre:"/[?&]action=([Cc]ustom[Rr]eport|[Rr]eport[Qq]uery|[Rr]un[Rr]eport)/";
  threshold:type both, track by_src, count 10, seconds 5;
  reference:cve,2026-10699;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000104; rev:1; )

