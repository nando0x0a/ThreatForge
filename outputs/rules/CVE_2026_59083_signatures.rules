# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# CVE-2026-59083: Apache Tomcat RewriteValve URL hex-encoding bypass.
# The vulnerability involves improper handling of percent-hex encoded
# characters in Tomcat's RewriteValve, allowing attackers to bypass
# security constraints by supplying hex-encoded path segments (e.g.,
# %2F, %2E, %25, double-encoding variants such as %252F) in HTTP
# request URIs that the rewrite rule normalises differently from the
# security constraint matcher. Affected versions: 8.5.0-8.5.100,
# 9.0.0.M1-9.0.119, 10.1.0-M1-10.1.56, 11.0.0-M1-11.0.23 [1][3].
# This rule targets HTTP requests to Tomcat default ports carrying
# suspicious percent-encoded path traversal or slash sequences that
# are characteristic of constraint-bypass attempts via RewriteValve.
# Because no PoC or PCAP is available, match logic is conservative
# and WILL produce false positives on legitimate encoded URLs.
# ANALYST REVIEW REQUIRED before any blocking deployment.

alert http $EXTERNAL_NET any -> $HOME_NET [8080,8443,8009,80,443] (
  msg:"THREATFORGE CVE-2026-59083 Apache Tomcat RewriteValve URL hex-encoding security constraint bypass attempt";
  flow:established,to_server;
  http.uri;
  pcre:"/(?:%(?:2[Ff]|5[Cc]|2[Ee]|25(?:2[Ff]|5[Cc]|2[Ee])|[Cc]0(?:[Aa][Ff]|[Bb][Dd]))){1,}/i";
  reference:cve,2026-59083;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-recon;
  sid:9000042; rev:1; )

