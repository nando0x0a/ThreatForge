# Confidence: PoC known — 19 public proof-of-concept(s) reported [6][7], including
# named exploit chain "wp2shell" targeting CVE-2026-60137 combined with CVE-2026-63030 [3].
# Active in-the-wild exploitation confirmed via CISA KEV [2] and honeypot captures [4].
# No packet-capture (PCAP) data source is available to this pipeline — this pattern is NOT
# verified against captured exploit traffic. Match logic targets the vulnerable parameter
# (author__not_in) as observed in WP_Query HTTP request patterns described in the advisory [3].
# SQL injection payloads are delivered via WordPress REST API or standard query-string
# requests; the pcre targets common SQLi metacharacter sequences in that parameter context.
# This is a PROPOSED DRAFT for analyst review. Validate and tune before production deployment.
# NOTE: CVE-2026-60137 is part of a two-CVE RCE chain ("wp2shell") with CVE-2026-63030 [3];
# this rule addresses only the SQLi component. A companion rule for CVE-2026-63030 is
# recommended. Affected versions: WordPress 6.8.x < 6.8.6, 6.9.x < 6.9.5, 7.0.x < 7.0.2 [1].
alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-60137 WordPress WP_Query author__not_in SQL injection attempt (wp2shell chain)";
  flow:established,to_server;
  http.uri;
  content:"author__not_in";
  nocase;
  pcre:"/author__not_in[^\&\s]*(?:%27|'|%22|\"|%2527|--|%2D%2D|%3B|;|\bUNION\b|\bSELECT\b|\bOR\b\s+[\w%]+=[\w%]+|0x[0-9a-fA-F]{2,})/iU";
  reference:cve,2026-60137;
  metadata:mitre_technique_id T1190, is_kev true, status experimental;
  classtype:attempted-admin;
  sid:9000137;
  rev:1; )

