# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-56398
# Product:   open webui
# Tags:      [HIGH] [POC]
# Score:     30
# Tier:      MONITOR
# Generated: 2026-07-21T04:37:02.225918Z
# Status:    OK
# ---

# Confidence: PoC known — public proof-of-concept exists per context PoC Availability [5].
# No packet-capture (PCAP) data source is available to this pipeline — this pattern is NOT verified
# against captured exploit traffic.
#
# Pattern basis: CVE-2026-56398 describes a stored XSS in Open WebUI < 0.9.5 [1] triggered via
# the OAuth authentication flow profile image endpoint [3]. The attack vector involves an SVG
# delivered as a data URI via the OAuth "picture" claim, which is improperly MIME-validated and
# subsequently served/rendered in a browser context [2][3]. Observable network behaviour targeted
# here is an HTTP response from the Open WebUI server containing an SVG data URI with embedded
# script content in the profile image context — the stored payload delivery phase.
# Analyst review required before deployment: SVG-in-data-URI is a broad pattern;
# tune $HOME_NET and URI path to match your Open WebUI deployment paths before enabling drop.
#
# CISA KEV: NOT listed as KEV at time of rule generation (5 days old) [1][4].
# MITRE Technique: T1059.007 (JavaScript/XSS execution via browser scripting).

alert http $HOME_NET any -> $EXTERNAL_NET any (
  msg:"THREATFORGE CVE-2026-56398 Open WebUI OAuth SVG XSS payload delivery attempt";
  flow:established,to_client;
  http.response_body;
  content:"data:image/svg+xml"; nocase;
  content:"<script"; distance:0; nocase;
  pcre:"/data:image\/svg\+xml[^\"'`]{0,512}<script[\s>]/si";
  reference:cve,2026-56398;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000042; rev:1; )

