# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-55040
# Product:   microsoft sharepoint
# Tags:      [RCE] [CRIT] [T1]
# Score:     90
# Tier:      CRITICAL — ACT NOW
# Generated: 2026-07-21T04:22:19.006688Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is described as a broken/weak
# authentication bypass in Microsoft Office SharePoint, exploitable over
# the network with no privileges and no user interaction (AV:N/PR:N/UI:N)
# [1][2]. Detection logic below targets anomalous unauthenticated HTTP
# requests to common SharePoint authentication and API endpoints that may
# indicate an auth-bypass attempt. Because the specific request structure,
# header manipulation, or token anomaly that triggers the vulnerability has
# NOT been disclosed in available advisory text [2], the content and PCRE
# patterns are inferred heuristics only — they are NOT derived from exploit
# traffic or a PoC.
#
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# ⚠ ANALYST REVIEW REQUIRED before deployment. High false-positive risk.
# Tune HTTP header inspection and threshold values for your environment.
# This rule is a PROPOSED DRAFT for analyst review only.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-55040 Microsoft SharePoint broken auth bypass attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/_api/"; nocase;
  pcre:"/\/_api\/(web|site|contextinfo|search|lists|securityinfo)/Ui";
  http.header; content:!"Authorization"; nocase;
  content:!"X-RequestDigest"; nocase;
  threshold:type both, track by_src, count 5, seconds 60;
  reference:cve,2026-55040;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000055; rev:1; )

