# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-61462
# Product:   gitlab
# Tags:      [RCE] [HIGH]
# Score:     60
# Tier:      STANDARD
# SEVERITY DISCREPANCY: NVD/vulnx says 8.6 (HIGH) — CVE.org (CNA, v4.0) says 9.2 (CRITICAL). See https://www.cve.org/CVERecord?id=CVE-2026-61462
# Generated: 2026-07-21T04:25:37.993534Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The advisory [2] identifies the vulnerable parameter as
# job_id in GitLab API requests handled by build/index.js [3]. Path traversal
# payloads (e.g., "../", URL-encoded variants) in the job_id value are the
# observable behaviour targeted here.
# No packet-capture (PCAP) data source is available to this pipeline — this
# pattern is NOT verified against captured exploit traffic.
#
# SEVERITY DISCREPANCY: NVD scores this CVSS 8.6 HIGH [1]; the CNA-published
# record at CVE.org scores it CVSS v4.0 9.2 CRITICAL [4]. Analysts should
# review both scores before determining response priority. The higher CNA
# score may reflect additional attack-path considerations under the CVSS v4.0
# framework.
#
# THIS RULE IS A PROPOSED DRAFT FOR ANALYST REVIEW BEFORE DEPLOYMENT.
# False-positive risk is elevated given the pattern targets URL path segments
# that may appear in legitimate requests. Tune to your mcp-gitlab deployment
# context before enabling in blocking mode.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-61462 mcp-gitlab job_id path traversal attempt";
  flow:established,to_server;
  http.uri;
  content:"/jobs/";
  pcre:"/\/jobs\/[^\/]*(?:%2e%2e|%252e|\.\.(?:%2f|%5c|\/|\\))/Ui";
  reference:cve,2026-61462;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-recon;
  sid:9000042; rev:1; )

