# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-10037
# Product:   ubuntu
# Tags:      [HIGH] [T1] [WIDE]
# Score:     50
# Tier:      STANDARD
# Generated: 2026-07-14T20:44:47.873860Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# DRAFT FOR ANALYST REVIEW — CVE-2026-10037
#
# Basis: The exploit requires a sandboxed application (e.g., Firefox Snap)
# to trigger a .jar MIME handler via the OpenURI portal exposed by
# xdg-desktop-portal-gtk [2]. The observable network vector is an HTTP
# response delivering a .jar file with a MIME type that the mailcap
# handler would process as executable (e.g., application/x-java-archive
# or application/java-archive). This rule targets inbound HTTP responses
# carrying such content to the home network.
#
# ANALYST NOTES:
# - CVSS 8.8 HIGH [1]; not currently listed in CISA KEV (is_kev false).
# - CVE is 5 days old; advisory detail is limited [2][3]. Match logic is
#   based solely on MIME type and file extension observable in HTTP traffic.
# - The rule targets the delivery phase (malicious .jar retrieval). The
#   xdg-desktop-portal-gtk / OpenURI interaction is a local IPC mechanism
#   and is not directly observable on the wire.
# - Tuning strongly recommended: application/java-archive and .jar are
#   legitimate in many environments. Consider scoping $HOME_NET to
#   hosts running affected Ubuntu OpenJDK Snap-confined applications.
# - SEVERITY DISCREPANCY: Only a single CVSS score of 8.8 HIGH is present
#   in the provided sources [1][3]; no conflicting score was surfaced.
#   Analyst should verify NVD and CNA records independently as this CVE
#   is only 5 days old and scoring may be updated.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-10037 OpenJDK Ubuntu JAR MIME sandbox escape delivery attempt";
  flow:established,to_client;
  http.response_body;
  content:"PK";
  depth:2;
  http.header;
  content:"application/";
  nocase;
  pcre:"/Content-Type\s*:\s*application\/(x-java-archive|java-archive|x-jar|jar)/i";
  http.uri;
  pcre:"/\.jar(\?[^\r\n]*)?$/i";
  reference:cve,2026-10037;
  metadata:mitre_technique_id T1203, is_kev false, status experimental;
  classtype:attempted-user;
  sid:9000004;
  rev:1; )

