# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-42533
# Product:   nginx
# Tags:      [RCE] [HIGH] [T1] [WIDE] [POC]
# Score:     100
# Tier:      CRITICAL — ACT NOW
# Generated: 2026-07-21T04:19:24.059183Z
# Status:    OK
# ---

# Confidence: PoC known — see [4][5]. No packet-capture (PCAP) data source
# is available to this pipeline — this pattern is NOT verified against captured
# exploit traffic.
#
# Pattern basis: The vulnerability (CVE-2026-42533) is a heap buffer overflow
# triggered by crafted HTTP requests containing malformed or oversized regex
# capture variable references (e.g., $1, $2 ... $N) within NGINX map directive
# string expressions [1][2][3]. The detection heuristic looks for HTTP requests
# bearing large numbers of consecutive regex capture variable references in a
# header or URI, which is the observable surface described in the advisory [2].
# Because no PCAP is available and the PoC repositories [4][5] were not
# directly inspectable, the specific byte pattern triggering the overflow is
# NOT confirmed. The pcre below is an approximation derived from the
# CVE/advisory description only. Analyst review and tuning against lab traffic
# is STRONGLY recommended before any deployment, especially given the RCE
# potential at CVSS 8.1 [1] with no authentication required and 4 public
# proof-of-concept(s) known to exist.
#
# DRAFT — proposed for analyst review only. Do not deploy without validation.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-42533 NGINX Plus/OSS map directive regex capture variable heap buffer overflow attempt";
  flow:established,to_server;
  http.header;
  pcre:"/(\$\d{1,3}[^\r\n]{0,64}){6,}/";
  threshold:type both, track by_src, count 3, seconds 10;
  reference:cve,2026-42533;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin;
  sid:9000042; rev:1; )

