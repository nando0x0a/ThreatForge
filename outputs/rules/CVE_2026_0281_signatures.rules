  http.uri; content:"/php/utils/"; nocase;
  http.header; content:"Referer|3a|"; nocase; pcre:"/Referer\s*:\s*https?:\/\/(?![^\/\s]*\$HOME_NET)[^\s]+/Hi";
  threshold:type limit, track by_src, count 1, seconds 60;
