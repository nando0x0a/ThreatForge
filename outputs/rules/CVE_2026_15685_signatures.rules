# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-15685
# Product:   ollama
# Tags:      [RCE] [HIGH]
# Score:     60
# Tier:      STANDARD
# Generated: 2026-07-21T04:25:00.232406Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is described as improper validation of
# an array index in the Ollama downloadBlob function, which is accessed via
# HTTP API requests (no authentication required [2]). The match targets the
# known Ollama blob download API endpoint path (/api/blobs/ or the OCI-style
# /v2/.../blobs/) from external hosts to internal Ollama service ports
# (default 11434). There is no empirical traffic pattern or exploit structure
# available beyond the advisory description [2]; the URI content match is
# based on the named vulnerable function (downloadBlob) and Ollama's
# documented REST API surface.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# CVSS: 7.5 (HIGH) AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H [2].
# is_kev: false — no CISA KEV entry identified in the provided context.
# ANALYST REVIEW REQUIRED before deployment. This is a proposed draft.
alert http $EXTERNAL_NET any -> $HOME_NET 11434 (
  msg:"THREATFORGE CVE-2026-15685 Ollama downloadBlob array index DoS attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/api/blobs/"; nocase; fast_pattern;
  threshold:type both, track by_src, count 10, seconds 5;
  reference:cve,2026-15685;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-dos; sid:9000004; rev:1; )

