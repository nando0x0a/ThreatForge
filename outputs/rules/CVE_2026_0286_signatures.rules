alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-0286 PAN-OS Authenticated CLI Command Injection Attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/php/utils/createRemoteAppwebSession.php";
  nocase; isdataat:!0,relative;
  pcre:"/[\;\|\`\$\(\)][[:space:]]*[a-zA-Z0-9\/\._\-]+/";
  threshold:type limit, track by_src, count 3, seconds 60;
  reference:cve,2026-0286;
  metadata:mitre_technique_id T1059.004, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000286; rev:1; )

