# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-59221
# Product:   open webui
# Tags:      [HIGH] [POC]
# Score:     30
# Tier:      MONITOR
# Generated: 2026-07-14T21:01:10.804322Z
# Status:    OK
# ---

# Confidence: PoC known — 1 public proof-of-concept exists; see [5].
# No packet-capture (PCAP) data source is available to this pipeline — this
# pattern is NOT verified against captured exploit traffic.
#
# Pattern basis: CVE-2026-59221 describes a path traversal in Open WebUI
# 0.9.6 (before 0.10.0) caused by insufficient decoding of percent-encoded
# sequences in _sanitize_proxy_path [1][4]. Attackers send crafted proxy
# paths containing double or mixed percent-encoding (e.g., %252e%252e,
# %2e%2e, or %2f sequences) to traverse outside intended directories [3][5].
# The PCRE targets common single- and double-encoded dot-dot-slash traversal
# patterns in the HTTP URI. No PCAP evidence is available; tune threshold
# and content anchoring after analyst review of actual exploit payloads
# from the PoC advisory [5].
#
# PROPOSED DRAFT — FOR ANALYST REVIEW BEFORE DEPLOYMENT.
# This rule has not been validated against live or captured exploit traffic.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-59221 Open WebUI path traversal via percent-encoded proxy path";
  flow:established,to_server;
  http.uri;
  content:"%2";
  pcre:"/(?:%252e%252e|%2e%2e|%252f|\.\.(?:%2f|%252f))/iU";
  reference:cve,2026-59221;
  reference:url,github.com/open-webui/open-webui/security/advisories/GHSA-frvj-c5qp-xj4w;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-recon;
  sid:9000004; rev:1; )

