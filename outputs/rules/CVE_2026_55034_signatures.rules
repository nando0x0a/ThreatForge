# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# CVE-2026-55034 | Microsoft Office SharePoint Stored XSS / Spoofing
# CVSS 7.3 (HIGH) [1]. Exploit requires an authenticated (authorized)
# attacker submitting malicious input that is later rendered in a
# SharePoint page [3]. The detection targets HTTP POST requests to
# SharePoint content-submission endpoints carrying common XSS payload
# indicators (script tags / javascript: URIs) in the body. Because no
# PoC or PCAP is available, the match logic is BROAD and carries a HIGH
# FALSE-POSITIVE RISK — analyst review and environment-specific tuning
# are strongly recommended before deployment.
# Priority Tier: STANDARD | Priority Score: 40 | Tags: [HIGH] [T1]
# THIS RULE IS A PROPOSED DRAFT FOR ANALYST REVIEW.

alert http $HOME_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-55034 Microsoft SharePoint Stored XSS spoofing attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/_layouts/"; nocase;
  pcre:"/\/_layouts\/[^\s]*\.(aspx|ashx|asmx)/iU";
  http.request_body;
  pcre:"/<script[\s>]|javascript\s*:/iU";
  reference:cve,2026-55034;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000104; rev:1; )

