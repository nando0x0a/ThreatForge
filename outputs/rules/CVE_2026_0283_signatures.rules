# DRAFT FOR ANALYST REVIEW — CVE-2026-0283 PAN-OS LSVPN Authentication Bypass
#
# Confidence: LOW
#   PoC status: No public PoC known — pattern inferred from the
#   CVE/advisory description only. [2]
#   PCAP status: No packet-capture (PCAP) data source is available to
#   this pipeline — this pattern is NOT verified against captured exploit
#   traffic.
#
# Severity discrepancy: NVD scores this CVSS 7.2 HIGH [1]; the CNA-published
#   record on CVE.org scores it CVSS v4.0 4.5 MEDIUM [3]. The vendor advisory
#   independently rates it 4.5 MEDIUM (Urgency: MODERATE, Exploit Maturity:
#   UNREPORTED) [2]. Analyst should assess which score reflects their
#   deployment risk before acting on this rule's priority.
#
# Detection rationale: PAN-OS LSVPN satellite-to-portal VPN establishment
#   uses UDP/4501 (IPsec NAT-T) and TCP/443 for portal authentication and
#   tunnel negotiation. An authentication bypass in LSVPN [2] would manifest
#   as unexpected IKE/IPsec negotiation attempts reaching the GlobalProtect
#   portal from untrusted sources. In absence of a PoC or PCAP, this rule
#   targets IKEv2 SA_INIT exchanges (exchange type 0x22) toward the PAN-OS
#   LSVPN portal port (UDP/4501) as a heuristic signal for unauthorized
#   satellite registration attempts. The specific byte offsets below align
#   to the IKEv2 fixed header: bytes 16-17 carry the Exchange Type (34 = 0x22
#   IKE_SA_INIT) and flags/message ID follow. This is structural protocol
#   matching only — specificity to the bypass mechanism is unavailable
#   without further advisory technical detail [2].
#
# Deployment recommendation: Run in alert-only mode. Tune $LSVPN_PORTAL
#   to the actual IP(s) of your PAN-OS GlobalProtect/LSVPN portal.
#   Validate against baseline IKE traffic before considering drop mode.
#   Correlation with PAN-OS logs for unauthorized satellite registration
#   events is strongly advised as a higher-fidelity signal.
#
# References: [1] NVD, [2] Palo Alto Networks advisory, [3] CVE.org CNA record

alert udp $EXTERNAL_NET any -> $HOME_NET 4501 (
  msg:"THREATFORGE CVE-2026-0283 PAN-OS LSVPN IKEv2 auth bypass attempt";
  flow:to_server;
  dsize:>28;
  content:"|00 00 00 00 00 00 00 00|"; offset:0; depth:8;
  content:"|00 00 00 00 00 00 00 00|"; offset:8; depth:8;
  content:"|22|"; offset:16; depth:1;
  threshold:type both, track by_src, count 3, seconds 60;
  reference:cve,2026-0283;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin;
  sid:9000104;
  rev:1; )

