# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# CVE-2026-55126 | Microsoft SharePoint Stored XSS / Spoofing
# CVSS: 7.3 HIGH [1] | KEV: Not listed | PoC: None known
# Priority Tier: STANDARD | Tags: [HIGH] [T1]
#
# Detection rationale: This vulnerability is a stored XSS in SharePoint
# delivered over HTTP. The rule attempts to match inbound HTTP POST
# requests to SharePoint content-submission endpoints carrying common
# XSS payload patterns (script injection via HTML event handlers or
# <script> tags). Because no PoC or PCAP is available, the match logic
# is necessarily broad and inference-based. Analyst review and tuning
# against local SharePoint traffic is STRONGLY recommended before any
# deployment. False-positive rate is expected to be non-trivial in
# environments with rich HTML content submission to SharePoint.
#
# NOTE: The advisory context retrieved from [2] was not fully rendered
# (JavaScript-dependent page) and yielded no specific endpoint or
# payload detail. Match patterns are derived solely from the CVE
# description [1][3] and general stored-XSS characteristics.
# SEVERITY NOTE: Only a single CVSS score of 7.3 (HIGH) was observed
# across available sources [1][2]; no severity discrepancy was detected.
#
# THIS IS A PROPOSED DRAFT FOR ANALYST REVIEW. Do not deploy to
# blocking/IPS mode without validation against representative traffic.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-55126 Microsoft SharePoint stored XSS spoofing attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; pcre:"/\/(sites|_layouts|_api|lists|pages|webparts)\//i";
  http.request_body;
  pcre:"/(<script[\s>]|on(?:load|error|mouseover|click|focus|blur|input|change|submit)\s*=|javascript\s*:)/i";
  reference:cve,2026-55126;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack;
  sid:9000104; rev:1; )

