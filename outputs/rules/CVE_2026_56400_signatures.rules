# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-56400
# Product:   open webui
# Tags:      [HIGH] [POC]
# Score:     30
# Tier:      MONITOR
# SEVERITY DISCREPANCY: NVD/vulnx says 8.3 (HIGH) — CVE.org (CNA, v4.0) says 9 (CRITICAL). See https://www.cve.org/CVERecord?id=CVE-2026-56400
# Generated: 2026-07-21T04:36:15.677182Z
# Status:    OK
# ---

# Confidence: PoC known — see [5] (public PoC referenced via VulnCheck advisory).
# No packet-capture (PCAP) data source is available to this pipeline — this
# pattern is NOT verified against captured exploit traffic.
#
# Pattern basis: The vulnerability is a CORS misconfiguration (allow_origins=*)
# on the /api/v1/functions endpoint in open-webui < 0.3.14 [3], enabling
# cross-origin requests from attacker-controlled sites to execute arbitrary
# code when an admin is authenticated [2]. The rule detects inbound HTTP
# requests to the target endpoint that carry a cross-origin Origin header
# pointing to an external (non-$HOME_NET) host — the observable network
# behaviour of a CORS-abuse attack against this endpoint.
#
# SEVERITY DISCREPANCY: NVD scores this CVE-2026-56400 as CVSS 8.3 HIGH [1],
# while the CNA-published record on CVE.org assigns CVSS v4.0 9.0 CRITICAL [4].
# Analysts should review both scores before determining deployment priority.
#
# Limitations: The Origin header value cannot be reliably matched to a specific
# attacker domain without threat-intel feeds. The pcre below matches any Origin
# that is NOT localhost/127.0.0.1/::1, which is a necessary but not sufficient
# condition for malicious cross-origin abuse. False positives are possible in
# environments where legitimate external origins access this API. Tune the
# $HOME_NET variable and consider allowlisting known-good origins before
# promoting beyond MONITOR status.
# DRAFT — FOR ANALYST REVIEW ONLY
alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-56400 open-webui CORS misconfiguration RCE attempt on /api/v1/functions";
  flow:established,to_server;
  http.uri; content:"/api/v1/functions"; nocase;
  http.header; content:"Origin:"; nocase;
  pcre:"/^Origin:\s*https?:\/\/(?!localhost|127\.0\.0\.1|\[::1\])[^\r\n]+/Hmi";
  reference:cve,2026-56400;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin;
  sid:9000004; rev:1; )

