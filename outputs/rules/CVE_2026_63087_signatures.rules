# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only [2][4]. The observable behaviour is an unauthenticated POST
# (or GET) to the internal plugin install endpoint in Grafana OnCall using
# hardcoded default values for stack_id and org_id to obtain a
# PluginAuthToken [2]. The specific endpoint path and parameter names are
# drawn from the VulnCheck advisory description [2]; exact field values/
# payload structure were not confirmed from a PoC or vendor patch diff.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# Analyst review is strongly recommended before deployment: if the advisory
# or a future PoC reveals the exact endpoint path or hardcoded id values,
# the pcre below should be tightened accordingly.
#
# DRAFT — proposed for analyst review only.
#
# CVE: CVE-2026-63087
# Product: Grafana OnCall <= 1.16.11
# CVSS: 9.8 CRITICAL [1]
# RCE: YES (AV:N/AC:L/PR:N/UI:N) [1]
# KEV: Not listed in CISA KEV at time of rule creation (CVE age: 3 days) [1][4]
# MITRE: T1190 (Exploit Public-Facing Application)

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-63087 Grafana OnCall unauthenticated plugin install endpoint access attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/plugin"; nocase; content:"install"; nocase; distance:0;
  pcre:"/\/plugin[s]?[\/\-_]?install/i";
  http.request_body; pcre:"/(?:stack_id|org_id)\b/i";
  threshold:type both, track by_src, count 3, seconds 60;
  reference:cve,2026-63087;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin;
  sid:9000087; rev:1; )

