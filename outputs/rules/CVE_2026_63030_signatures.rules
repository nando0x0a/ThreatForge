# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-63030
# Product:   wordpress
# Tags:      [KEV] [RCE] [CRIT] [T1] [POC]
# Score:     150
# Tier:      CRITICAL — ACT NOW
# Generated: 2026-07-21T06:24:05.477095Z
# Status:    OK
# ---

# Confidence: PoC known — see [6] and [7]. 86 public proof-of-concept(s) reported [6][7].
# No packet-capture (PCAP) data source is available to this pipeline — this pattern is NOT
# verified against captured exploit traffic.
#
# Pattern basis: CVE-2026-63030 describes a SQL injection via the WordPress REST API batch
# endpoint combined with the author__not_in WP_Query parameter [1][3][4]. Observable network
# behaviour is expected to include HTTP POST requests to the REST API batch endpoint
# (/wp-json/batch/v1 or /__batch/ variants) containing the author__not_in parameter
# in the JSON body. The pcre below targets this combination. Because no PCAP is available
# and PoC source code focuses on scanning/scanning infrastructure [6][7] rather than raw
# request captures, the match logic is inferred from the advisory description [3][4] and
# should be treated as LOW-CONFIDENCE until validated against real exploit traffic.
# Analyst review and tuning REQUIRED before production deployment.
# This output is a PROPOSED DRAFT for analyst review — CVE-2026-63030.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-63030 WordPress REST API Batch SQLi/RCE attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/wp-json/"; nocase;
  pcre:"/\/wp-json\/(?:batch\/v1|v\d+\/[^?#]*batch)/i";
  http.request_body; content:"author__not_in"; nocase;
  threshold:type limit, track by_src, count 1, seconds 60;
  reference:cve,2026-63030;
  metadata:mitre_technique_id T1190, is_kev true, status experimental;
  classtype:attempted-admin; sid:9000100; rev:1; )

