# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-60005
# Product:   nginx
# Tags:      [RCE] [HIGH] [T1] [WIDE]
# Score:     90
# Tier:      CRITICAL — ACT NOW
# Generated: 2026-07-21T04:21:37.042129Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# NOTE — ANALYST REVIEW REQUIRED BEFORE DEPLOYMENT:
# CVE-2026-60005 affects NGINX Plus and NGINX Open Source ngx_http_slice_module
# when the slice directive is active and unnamed regex captures are configured,
# or during background cache updates [1][2]. The vulnerability manifests
# server-side (uninitialized memory access) and is NOT triggered by a
# distinctive client-supplied payload string — there is no known malformed
# header, URI token, or protocol anomaly that uniquely fingerprints
# exploitation attempts. This rule therefore targets HTTP Range requests
# directed at NGINX servers, which is the normal request vector for
# ngx_http_slice_module (slice responses are driven by Range/byte-range
# headers). This is a HIGH FALSE-POSITIVE heuristic, not a precise
# exploit signature. Tune $NGINX_SERVERS to scope impact.
# CVSS 8.2 HIGH [1]; RCE classified network-exploitable (AV:N/PR:N/UI:N).
# No CISA KEV entry confirmed in provided context; is_kev set to false.
# MITRE ATT&CK: T1190 (Exploit Public-Facing Application).
# Severity discrepancy: only a single CVSS score of 8.2 (HIGH) is present
# in the provided context [1]; no conflicting score from another source was
# supplied. Analyst should verify against [2][3] for any vendor-assigned
# score that may differ.
# SID: 9000004 — assigned within ThreatForge range.

alert http $EXTERNAL_NET any -> $HOME_NET 80,443,8080,8443 (
  msg:"THREATFORGE CVE-2026-60005 NGINX ngx_http_slice_module memory disclosure DoS attempt - Range header heuristic";
  flow:established,to_server;
  http.header;
  content:"Range|3a 20|bytes=";
  nocase;
  pcre:"/^Range\s*:\s*bytes=\d+-\d*/Hmi";
  threshold:type both, track by_src, count 10, seconds 5;
  reference:cve,2026-60005;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-dos;
  sid:9000004; rev:1; )

