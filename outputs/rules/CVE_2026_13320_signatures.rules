alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-13320 GitLab CE/EE Stored XSS injection attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; pcre:"/\/(issues|merge_requests|snippets|wikis|notes|comments|discussions)(\/[0-9]+)?(\/[a-z_]+)?(\?|$)/i";
  http.request_body; pcre:"/<\s*(script|img|svg|iframe|object|embed|body|details|video|audio|source|track|input|textarea|select|form|meta|link|style|base)[^>]*(\s+on\w+\s*=|\s+src\s*=\s*[\"']?\s*javascript:|\s+href\s*=\s*[\"']?\s*javascript:|\s+xlink:href\s*=\s*[\"']?\s*javascript:|<\s*\/?\s*script\s*>)/si";
  reference:cve,2026-13320;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000004; rev:1; )
