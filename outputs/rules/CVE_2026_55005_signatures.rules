# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is a heap-based buffer overflow in
# Microsoft Exchange Server triggered by authorized remote attackers over
# the network [1][2]. No packet-capture (PCAP) data source is available
# to this pipeline — this pattern is NOT verified against captured exploit
# traffic. The content matches below target Exchange OWA/EWS/RPC HTTP
# endpoints commonly associated with Exchange RCE exploitation; they are
# heuristic and broad. Analyst review and tuning are strongly recommended
# before any deployment. This rule is a PROPOSED DRAFT for analyst review.
# NOTE: Because exploitation requires attacker authorization [1][2], this
# rule focuses on anomalous POST activity to Exchange service endpoints
# with oversized bodies that may indicate heap overflow triggering. False
# positive rate is expected to be non-trivial in environments with heavy
# legitimate Exchange traffic.

alert http $EXTERNAL_NET any -> $HOME_NET [443,80,8443] (
  msg:"THREATFORGE CVE-2026-55005 Microsoft Exchange Server heap buffer overflow RCE attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/ews/exchange.asmx"; nocase;
  http.header_names; content:"Authorization"; nocase;
  dsize:>65000;
  threshold:type limit, track by_src, count 1, seconds 60;
  reference:cve,2026-55005;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000004; rev:1; )

