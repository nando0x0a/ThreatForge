#
# NOTE: CVE-2026-44752 describes a stored XSS vulnerability in SAP
# NetWeaver Application Server Java, triggered via crafted URLs that
# inject malicious JavaScript. The advisory snippet references SAP
# authentication/OAuth redirect flows and cookie-setting JS, but does
# not expose a specific vulnerable endpoint or URL parameter name.
# The match logic below targets common XSS delivery patterns (script
# injection via URL) directed at SAP NetWeaver HTTP ports and should
# be treated as a BROAD, LOW-FIDELITY heuristic only. An analyst MUST
# review and refine the pattern against actual SAP NetWeaver traffic
# before deployment. False-positive rate is expected to be HIGH without
# further tuning.
#
# SEVERITY NOTE: CVSS score is 8.2 HIGH per the provided context [1].
# CVE is 6 days old; no CISA KEV listing is reflected in the provided
# context (is_kev set to false accordingly).
#
# This rule is a PROPOSED DRAFT for analyst review only.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-44752 SAP NetWeaver AS Java stored XSS attempt via crafted URL";
  flow:established,to_server;
  http.uri;
  content:"/irj/";
  pcre:"/<script[\s>]|javascript:|on(?:load|error|mouseover|click|focus)\s*=/iU";
  http.header;
  content:"Host";
  reference:cve,2026-44752;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:web-application-attack;
  sid:9000044; rev:1; )

