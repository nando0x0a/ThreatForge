# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-20297
# Product:   splunk
# Tags:      [HIGH]
# Score:     20
# Tier:      MONITOR
# Generated: 2026-07-21T04:39:54.873607Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The advisory (SVD-2026-0703 [2]) describes a path traversal
# in the Splunk app installation workflow where the installation path is not
# restricted to the intended app directory. Observable network behaviour is
# inferred as an HTTP POST to Splunk's app install/upload API endpoint containing
# path traversal sequences (e.g., "../") in the uploaded app package name or
# installation path parameter.
# No packet-capture (PCAP) data source is available to this pipeline — this
# pattern is NOT verified against captured exploit traffic.
# Analyst note: This rule targets the Splunk REST API app installation endpoint
# and looks for path traversal sequences. It will require tuning for your
# environment's Splunk management port (default 8089 or 8000). The exploit
# requires the attacker to hold edit_local_apps and install_apps capabilities [2],
# reducing likelihood of exploitation by low-privileged users. CVSS 7.2 HIGH [1].
# Affected versions: Splunk Enterprise < 10.4.1 / 10.2.5 / 10.0.8 / 9.4.13 /
# 9.3.14; Splunk Cloud Platform < 10.5.2605.0 / 10.4.2604.6 / 10.2.2510.18 /
# 10.1.2507.24 [1][2]. THIS IS A PROPOSED DRAFT FOR ANALYST REVIEW.
alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-20297 Splunk Enterprise app install path traversal attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/services/apps/local"; nocase;
  pcre:"/\/services\/apps\/(?:local|appinstall)[^\"]*(?:%2e%2e|%252e%252e|\.\.)[^\"]*(?:\/|%2f)/i";
  reference:cve,2026-20297;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000004; rev:1; )

