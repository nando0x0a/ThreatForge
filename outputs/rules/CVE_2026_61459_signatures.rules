# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-61459
# Product:   kubernetes
# Tags:      [RCE] [CRIT] [WIDE]
# Score:     80
# Tier:      HIGH PRIORITY
# Generated: 2026-07-14T20:21:01.614694Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. Specifically, the CVE describes argument injection via
# resourceType and name parameters containing leading dashes, used to inject
# --server flag into kubectl invocations through MCP Server Kubernetes structured
# tools [1][3][4]. The detectable network behaviour targeted here is an MCP
# tool-call payload (JSON over HTTP) containing parameter values that begin with
# dashes and include "--server" to redirect kubectl to an attacker-controlled
# API server [2].
# No packet-capture (PCAP) data source is available to this pipeline — this
# pattern is NOT verified against captured exploit traffic.
# NOTE: MCP Server Kubernetes typically exposes its API over HTTP (often
# localhost or internal network), so detection coverage may be limited to
# environments where this traffic traverses a monitored network segment.
# Analyst review is strongly recommended before deployment. This is a proposed
# draft for analyst review.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-61459 MCP-Server-Kubernetes argument injection --server flag attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.request_body;
  content:"--server";
  nocase;
  pcre:"/[\"\s,:\[]([-]{1,2}server\s*[\"\s,=]|\"[-]{1}[-a-z]*\"|\"[-]{1,2}server)/i";
  threshold:type limit, track by_src, count 1, seconds 60;
  reference:cve,2026-61459;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin;
  sid:9000004;
  rev:1; )

