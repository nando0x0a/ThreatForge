  msg:"THREATFORGE CVE-2026-54528 JupyterLab Git information disclosure via excluded_paths bypass";
  flow:established,to_server; http.method; content:"GET"; http.uri;
  pcre:"/\/api\/contents\/[^\/]*(?i:[A-Z][a-z]|[a-z][A-Z])[^\/]*(?:\/|$)/U";
  http.uri; content:"/api/contents/"; nocase;
  reference:cve,2026-54528;
