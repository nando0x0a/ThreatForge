# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-33382
# Product:   grafana
# Tags:      [RCE] [HIGH]
# Score:     60
# Tier:      STANDARD
# Generated: 2026-07-14T20:41:32.373649Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability involves oversized HTTP request bodies
# sent to Grafana API endpoints with no authentication required [2]. The
# threshold and dsize values below are heuristic estimates based on the
# described memory-exhaustion mechanism; they have NOT been calibrated
# against real attack traffic.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# CVSS 7.5 HIGH [1]; no CISA KEV entry confirmed at time of rule authoring.
# THIS RULE IS A PROPOSED DRAFT FOR ANALYST REVIEW ONLY.
# Analysts should validate dsize threshold and targeted URI paths against
# their Grafana deployment before deploying. Common API paths affected
# (per advisory description [2]) are inferred — specific endpoints not
# enumerated in available advisory text. Tune accordingly.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-33382 Grafana API oversized request body DoS attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; pcre:"/\/api\//i";
  http.request_body; dsize:>1048576;
  threshold:type both, track by_src, count 3, seconds 30;
  reference:cve,2026-33382;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-dos; sid:9000010; rev:1; )

