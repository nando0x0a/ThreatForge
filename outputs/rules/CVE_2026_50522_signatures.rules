# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-50522
# Product:   sharepoint_server
# Tags:      [KEV] [RCE] [CRIT]
# Score:     120
# Tier:      CRITICAL — ACT NOW
# Generated: 2026-07-22T03:17:32.553383Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is described as insecure deserialization
# of untrusted data in Microsoft SharePoint, network-exploitable with no
# authentication or user interaction required (AV:N/PR:N/UI:N) [1][2].
# Active exploitation has been observed in the wild per VulnCheck KEV
# (added 2026-07-20) [2] and watchTowr reporting [4], but no PoC source
# or PCAP sample was available to this pipeline at rule-generation time.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# Match rationale: SharePoint deserialization attacks are typically delivered
# via HTTP POST to known API/service endpoints (e.g., /_vti_bin/, /_api/,
# /_layouts/). The pcre targets .NET ViewState/SOAP/XML serialization
# artefacts (e.g., __VIEWSTATE tokens, BinaryFormatter magic bytes 0x00 0x01
# 0x00 0x00, or TypeConfuseDelegate/ObjectDataProvider class names) that are
# common indicators of deserialization payload delivery. These are
# heuristic-only patterns; tuning against site-specific SharePoint traffic
# is STRONGLY recommended before any deployment. This is a PROPOSED DRAFT
# for analyst review — do not deploy to block/drop without validation.
alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-50522 Microsoft SharePoint insecure deserialization RCE attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/_vti_bin/"; nocase; fast_pattern;
  pcre:"/\x00\x01\x00\x00|__VIEWSTATE|ObjectDataProvider|TypeConfuseDelegate|BinaryFormatter|YISerializationBinder/i";
  threshold:type both, track by_src, count 3, seconds 60;
  reference:cve,2026-50522;
  metadata:mitre_technique_id T1190, is_kev true, status experimental;
  classtype:attempted-admin; sid:9000522; rev:1; )

