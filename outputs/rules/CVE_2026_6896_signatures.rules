# Generated: 2026-07-14T21:11:06.107351Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only. The vulnerability is a stored XSS in
# GitLab EE requiring an authenticated developer role; network-observable
# behaviour is limited to HTTP POST/PUT requests carrying script payloads
# to GitLab content endpoints (e.g., issue/MR bodies, wiki pages, snippets).
# The advisory context retrieved [2][3] did not contain specific payload
# patterns or affected endpoint paths — match logic below targets generic
# stored XSS injection patterns directed at GitLab API/UI write endpoints
# and should be treated as LOW-CONFIDENCE without PCAP or PoC validation.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# Analyst review is strongly recommended before deployment.
#
# SEVERITY NOTE: CVSS score of 8.7 (HIGH) [1] is sourced from the NVD
# record. No discrepancy between sources was flagged in the provided context.
#
# MITRE mapping: T1059.007 (JavaScript execution via XSS / stored content).
# KEV status: Not listed in CISA KEV per provided context (is_kev false).
# Affected versions: GitLab EE >= 13.11 < 18.11.7, 19.0 < 19.0.4,
#                    19.1 < 19.1.2 [1][4].
# Priority Tier: MONITOR (Priority Score: 20) [1].

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-6896 GitLab EE stored XSS injection attempt via write endpoint";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/gitlab"; nocase; isdataat:!1,relative;
  pcre:"/\/(issues|merge_requests|wikis|snippets|notes|discussions)(\/[^\/]*)?(\?|$|\/)/iU";
  http.request_body;
  pcre:"/<script[\s>]|javascript\s*:|on(?:load|error|mouseover|click|focus|blur)\s*=/i";
  reference:cve,2026-6896;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack;
  sid:9006896; rev:1; )

