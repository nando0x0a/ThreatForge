alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-6896 GitLab EE Stored XSS via Developer Input";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; pcre:"/\/(api\/v\d+|[\w\-]+)\/(issues|merge_requests|snippets|wikis|notes|descriptions|labels|milestones|epics)/i";
  http.request_body; pcre:"/<\s*(script|img|svg|iframe|object|embed|details|body|html)[^>]*?(on\w+\s*=|javascript\s*:|src\s*=\s*[\"']?\s*javascript|data\s*:\s*text\/html)[^>]*?>/si";
  reference:cve,2026-6896;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000004; rev:1; )

