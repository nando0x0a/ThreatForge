alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-6896 GitLab EE Stored XSS via Developer Input";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; pcre:"/\/(api\/v4\/(projects|groups)|[-\w]+\/-\/(issues|merge_requests|wikis|snippets|milestones|epics))/i";
  http.request_body; pcre:"/<\s*script[^>]*>|javascript\s*:|on(?:load|error|mouseover|click|focus|blur)\s*=/i";
  threshold:type limit, track by_src, count 3, seconds 60;
  reference:cve,2026-6896;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000042; rev:1; )

