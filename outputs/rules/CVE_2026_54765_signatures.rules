alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-54765 Traefik Kubernetes Gateway API HTTPRoute cross-namespace access control bypass attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/apis/gateway.networking.k8s.io/"; nocase;
  http.request_body; content:"HTTPRoute"; nocase;
  pcre:"/\"namespace\"\s*:\s*\"[^\"]+\"\s*(?:[^}]*\"backendRefs\"|[^}]*\"filters\")/";
  threshold:type both, track by_src, count 5, seconds 30;
  reference:cve,2026-54765;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000104; rev:1; )

