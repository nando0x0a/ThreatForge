# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# IMPORTANT ANALYST NOTES:
# CVE-2026-58598 describes a LOCAL privilege escalation via race condition
# in the Windows Backup Engine (CVSS 7.0 HIGH [1][2]). Race condition/LPE
# vulnerabilities of this class do NOT produce distinctive network-layer
# indicators — exploitation occurs entirely in local process/kernel space
# with no characteristic network payload to match against.
#
# This rule is a BEST-EFFORT heuristic only. It targets SMB-based remote
# invocation of Windows Backup Engine RPC/named-pipe interfaces (e.g.,
# wbengine service communications), which represent the closest
# network-observable surface associated with this component. The match
# logic is structurally plausible but has NO evidentiary basis in captured
# exploit traffic or a public PoC.
#
# Recommended analyst actions before deployment:
#   1. Validate against baseline Windows Backup Engine traffic in your
#      environment — expect HIGH false-positive rate.
#   2. Pair with host-based detection (e.g., Sysmon EID 8 CreateRemoteThread,
#      EID 10 process access on svchost hosting wbengine, privilege change
#      events) for meaningful coverage of T1611/T1068.
#   3. Reassess if a public PoC or PCAP becomes available.
#   4. NOT recommended for IPS (drop) mode without substantial tuning.
#
# SEVERITY DISCREPANCY NOTE: Only a single CVSS score of 7.0 (HIGH) is
# present in the supplied context [1][2]. No discrepancy between sources
# was detected. If additional scoring sources (e.g., vendor-assigned vs.
# NVD-assigned) become available, re-evaluate before finalising
# deployment posture.
#
# This rule is a PROPOSED DRAFT for analyst review. Do not deploy to
# production without independent validation.

alert tcp $HOME_NET any -> $HOME_NET 445 (
  msg:"THREATFORGE CVE-2026-58598 Windows Backup Engine wbengine SMB named-pipe access attempt - LPE race condition";
  flow:established,to_server;
  content:"|FF|SMB"; offset:4; depth:4; nocase;
  content:"wbengine"; nocase; distance:0;
  threshold:type both, track by_src, count 10, seconds 5;
  reference:cve,2026-58598;
  metadata:mitre_technique_id T1068, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000100; rev:1; )

