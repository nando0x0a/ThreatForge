#
# CVE-2026-20296 | Splunk Enterprise / Splunk Cloud Platform — Stored XSS via Deployment Server
# endpoints lacking CSRF token validation and improper SPL input neutralization. [2]
# The attack is delivered over HTTP(S) to Splunk Web's Deployment Server endpoints, using
# caller-supplied input embedded into an SPL search. [2]
# Observable: HTTP GET requests to known Deployment Server endpoint paths containing
# script injection patterns or unencoded SPL metacharacters in query parameters.
# No attacker-controlled fixed payload is documented; match logic targets the endpoint path
# combined with common XSS/SPL injection indicators. Analyst tuning is strongly recommended
# before any enforcement action is taken.
# MITRE Technique: T1059.007 (JavaScript for Automation / stored XSS leading to arbitrary
# command execution as splunk-system-user).
# Affected versions: Splunk Enterprise < 10.4.1, 10.2.5, 10.0.8, 9.4.13;
# Splunk Cloud Platform < 10.5.2605.0, 10.4.2604.7, 10.3.2512.16, 10.2.2510.18,
# 10.1.2507.24. [1][2]
# Priority Tier: MONITOR. Not currently listed in CISA KEV.
# THIS IS A PROPOSED DRAFT FOR ANALYST REVIEW.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-20296 Splunk Deployment Server XSS/SPL injection attempt via GET";
  flow:established,to_server;
  http.method; content:"GET";
  http.uri; content:"/en-US/app/"; nocase;
  http.uri; content:"deployment"; nocase;
  http.uri; pcre:"/[<>\"\'%2[Ff]script|%3[Cc]|%3[Ee]|\|[a-zA-Z]|\$\{[^}]+\}/i";
  reference:cve,2026-20296;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000042; rev:1; )

