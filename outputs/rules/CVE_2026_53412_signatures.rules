# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# ANALYST REVIEW REQUIRED BEFORE DEPLOYMENT.
#
# CVE-2026-53412 — Zoom Desktop/VDI Client and Meeting SDK for Windows.
# Vulnerability: Authentication bypass via improper input validation,
# enabling unauthenticated account takeover over the network [1][2][3].
# CVSS 9.8 CRITICAL (AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H) [1].
# No PoC is publicly available as of time of rule authoring (CVE age: 3 days).
#
# The advisory (ZSB-26014) [2] does not disclose the specific protocol path,
# request structure, or authentication endpoint exploited by this vulnerability.
# Because no PoC or PCAP data is available, the match logic below targets
# Zoom's documented client-to-server signalling port (TCP 8801) and probes
# for the Zoom proprietary framing header bytes commonly observed in
# Zoom meeting SDK traffic, combined with a zero-length or absent
# credential/auth field heuristic (empty auth token in login request).
# This is a BEST-EFFORT structural heuristic only. False-positive and
# false-negative rates are unknown. Do NOT deploy in IPS (drop) mode
# without analyst validation against representative Zoom traffic in your
# environment.
#
# Recommended analyst actions:
#   1. Validate or refute the byte patterns against a Zoom packet capture
#      from your environment before enabling.
#   2. Monitor Zoom security bulletin ZSB-26014 [2] for technical indicators.
#   3. Apply vendor patches immediately — prioritise over detection.
#   4. Re-rev this rule when PoC or PCAP evidence becomes available.

alert tcp $EXTERNAL_NET any -> $HOME_NET 8801 (
  msg:"THREATFORGE CVE-2026-53412 Zoom Client Windows auth bypass attempt - EXPERIMENTAL LOW CONFIDENCE";
  flow:established,to_server;
  dsize:<64;
  content:"|5a 4d|"; offset:0; depth:2;
  pcre:"/^\x5a\x4d[\x00-\xff]{2}\x00{4,}/";
  threshold:type both, track by_src, count 3, seconds 10;
  reference:cve,2026-53412;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000044; rev:1; )

