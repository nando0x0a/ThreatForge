# description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# IMPORTANT ANALYST NOTES:
# CVE-2026-55006 describes a LOCAL privilege escalation in Microsoft Exchange
# Server via broken/insufficient access control [1][2]. Local privilege
# escalation vulnerabilities are inherently difficult to detect at the network
# layer, as exploitation typically occurs via local process or IPC calls rather
# than distinct external network traffic. This rule targets Exchange's HTTP
# management/EWS/ECP endpoints as the most plausible network-observable surface
# for an authenticated local attacker abusing access control weaknesses, but
# the specific HTTP path, method, or payload signature exploited is NOT known
# from the available advisory detail [2]. The match logic below is a
# conservative structural heuristic and has a HIGH risk of false positives
# and/or false negatives. Analyst review and tuning against local Exchange
# traffic is strongly recommended before any deployment.
# Advisory source [2] rendered without meaningful technical content (JS-dependent
# page returned no parsed detail). No CISA KEV status confirmed in provided
# context; is_kev set to false.
# Priority Tier: STANDARD | Priority Score: 40 | Tags: [HIGH] [T1]

alert http $HOME_NET any -> $HOME_NET [443,80,5985,5986] (
  msg:"THREATFORGE CVE-2026-55006 Microsoft Exchange Server broken access control local privilege escalation attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/ecp/"; nocase; fast_pattern;
  pcre:"/\/ecp\/(?:default\.aspx|RulesEditor\/|PersonalSettings\/|[^\"\'<>]{0,120})/Ui";
  http.header; content:"X-OWA-ExplicitLogonUser"; nocase;
  threshold:type both, track by_src, count 10, seconds 30;
  reference:cve,2026-55006;
  metadata:mitre_technique_id T1068, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000100; rev:1; )

