# ThreatForge Output — SIGNATURES
# CVE:       CVE-2026-15416
# Product:   kubernetes
# Tags:      [HIGH] [WIDE]
# Score:     30
# Tier:      MONITOR
# Generated: 2026-07-21T04:38:31.224806Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
#
# CVE-2026-15416 | Argo CD repo-server unauthenticated RCE
# CVSS: 8.9 (HIGH) [1] | is_kev: false (not in CISA KEV at time of rule
# authorship) | Age: 6 days | Priority Tier: MONITOR
#
# The vulnerability permits unauthenticated remote code execution via
# direct network access to the Argo CD repo-server. The repo-server
# listens on TCP 8081 (default gRPC port) and exposes an unauthenticated
# gRPC surface. This rule targets unauthenticated connection attempts to
# that port exhibiting gRPC framing, consistent with exploitation of the
# unauthenticated access path described in the CVE [1][4].
#
# WARNING: The repo-server port (TCP 8081) should NOT be externally
# reachable under normal Argo CD deployment guidance. Traffic from
# $EXTERNAL_NET to this port is anomalous regardless of exploit content.
#
# Rule covers: gRPC magic byte framing (0x00 = uncompressed data frame)
# on the repo-server port originating from external sources.
# Low-specificity match due to absence of PoC or PCAP data — analyst
# review and environment-specific tuning REQUIRED before deployment.
# This is a proposed draft for analyst review.

alert tcp $EXTERNAL_NET any -> $HOME_NET 8081 (
  msg:"THREATFORGE CVE-2026-15416 Argo CD repo-server unauthenticated RCE attempt";
  flow:established,to_server;
  content:"PRI * HTTP/2.0|0d 0a 0d 0a 53 4d 0d 0a 0d 0a|";
  nocase; offset:0; depth:24;
  pcre:"/^\x50\x52\x49\x20\x2a\x20\x48\x54\x54\x50\/2\.0/";
  threshold:type both, track by_src, count 3, seconds 30;
  reference:cve,2026-15416;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-admin; sid:9000042; rev:1; )

