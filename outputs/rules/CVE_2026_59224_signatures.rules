# Tier:      MONITOR
# Generated: 2026-07-14T21:04:30.202437Z
# Status:    OK
# ---

# Confidence: No public PoC known — pattern inferred from the
# CVE/advisory description only. The vulnerability involves an unencoded
# session_id and a forwarded X-User-Id HTTP header in the Open WebUI
# terminal backend, allowing attackers to impersonate other users by
# crafting requests with an arbitrary X-User-Id header value [1][2].
# The match targets HTTP requests to the terminal backend endpoint
# carrying an X-User-Id header, which is the observable network
# behaviour described in the advisory [2]. This is a broad heuristic;
# legitimate internal proxies may also set this header. Analyst tuning
# of source/destination networks and the URI path is strongly advised
# before deployment.
#
# PoC status: No public PoC known — pattern inferred from the
# CVE/advisory description only.
#
# PCAP status: No packet-capture (PCAP) data source is available to
# this pipeline — this pattern is NOT verified against captured exploit
# traffic.
#
# PROPOSED DRAFT — FOR ANALYST REVIEW BEFORE DEPLOYMENT.
# CVE: CVE-2026-59224 | Product: Open WebUI < 0.10.0
# Priority Tier: MONITOR | CVSS: 8.0 HIGH
# CISA KEV: Not indicated in available sources.

alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-59224 Open WebUI terminal broken access control X-User-Id impersonation attempt";
  flow:established,to_server;
  http.uri; content:"/terminal"; nocase;
  http.header; content:"X-User-Id:"; nocase;
  pcre:"/^X-User-Id\s*:\s*\S+/Hmi";
  reference:cve,2026-59224;
  metadata:mitre_technique_id T1190, is_kev false, status experimental;
  classtype:attempted-user;
  sid:9000042; rev:1; )

