alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-59224 Open WebUI broken access control X-User-Id impersonation attempt";
  flow:established,to_server;
  http.uri; content:"/terminal";
  http.header; content:"X-User-Id:";
  pcre:"/^X-User-Id\s*:\s*\d+/Hmi";
  reference:cve,2026-59224;
