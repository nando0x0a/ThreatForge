# Confidence: No public PoC known — pattern inferred from the CVE/advisory
# description only. The vulnerability is a stored XSS in the MOVEit Transfer
# Ad Hoc module [1][2], so detection targets HTTP POST requests to the Ad Hoc
# module endpoint carrying script-injection payloads. The Ad Hoc module path
# and exact parameter names are not confirmed in available advisory text [2]
# (advisory page returned non-substantive content); paths below are inferred
# from known MOVEit Transfer URL structure and common stored-XSS payload
# patterns. Analyst review of actual MOVEit Transfer traffic is strongly
# advised before deployment.
# No packet-capture (PCAP) data source is available to this pipeline —
# this pattern is NOT verified against captured exploit traffic.
# DRAFT — FOR ANALYST REVIEW ONLY. CVE-2026-11903.
alert http $EXTERNAL_NET any -> $HOME_NET any (
  msg:"THREATFORGE CVE-2026-11903 MOVEit Transfer Ad Hoc stored XSS attempt";
  flow:established,to_server;
  http.method; content:"POST";
  http.uri; content:"/adhoc"; nocase;
  http.request_body;
  content:"<script"; nocase;
  pcre:"/(<script[\s>]|javascript\s*:|on(?:load|error|mouseover|click|focus)\s*=)/i";
  reference:cve,2026-11903;
  metadata:mitre_technique_id T1059.007, is_kev false, status experimental;
  classtype:web-application-attack; sid:9000004; rev:1; )

